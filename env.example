# Kopiera denna fil till .env och fyll i dina riktiga uppgifter.
# Lägg ALDRIG .env i Git / dela den publikt.

# Supabase — hittas under Project Settings > API i din Supabase-dashboard
SUPABASE_URL=
SUPABASE_KEY=


# Extern källa — fyll i när du vet exakt API-endpoint och nyckel
EXTERNAL_API_URL= 
EXTERNAL_API_KEY=

# Var exporterade xlsx/csv-filer ska sparas
EXPORT_DIR=./exports